---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  schema?: object;
  noindex?: boolean;
}

const {
  title,
  description = site.descricao,
  image = site.ogImage,
  type = 'website',
  publishedDate,
  schema,
  noindex = false,
} = Astro.props;

const tituloFinal = title ? `${title} | ${site.nome}` : `${site.nome} — ${site.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).toString();
const imagemAbsoluta = new URL(image, Astro.site ?? site.url).toString();

// Schema.org padrão (WebSite) caso a página não forneça um próprio
const schemaPadrao = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.nome,
  url: site.url,
  description: site.descricao,
  inLanguage: site.idioma,
};
const schemaFinal = schema ?? schemaPadrao;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{tituloFinal}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={site.autor} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.nome} />
    <meta property="og:title" content={tituloFinal} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imagemAbsoluta} />
    <meta property="og:locale" content="pt_BR" />
    {publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloFinal} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imagemAbsoluta} />

    <!-- Tipografia Inter (self-hosted, variável) — preload do LCP, sem terceiros -->
    <link
      rel="preload"
      href="/fonts/inter-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script type="application/ld+json" set:html={JSON.stringify(schemaFinal)} />
  </head>
  <body class="flex min-h-screen flex-col font-sans">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
