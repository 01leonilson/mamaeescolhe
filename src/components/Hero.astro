---
import { site } from '../config/site';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradiente-mamae opacity-10"></div>
  <div class="absolute -right-24 -top-24 -z-10 h-72 w-72 rounded-full bg-rosa-light/30 blur-3xl"></div>
  <div class="absolute -bottom-24 -left-24 -z-10 h-72 w-72 rounded-full bg-lilas-light/30 blur-3xl"></div>

  <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:py-28">
    <span class="mb-4 inline-block rounded-full bg-white/70 px-4 py-1.5 text-sm font-semibold text-lilas-dark shadow-suave dark:bg-escuro/60 dark:text-lilas-light">
      Reviews • Guias • Enxoval
    </span>
    <h1 class="mx-auto max-w-3xl bg-gradiente-mamae bg-clip-text text-4xl font-extrabold leading-tight text-transparent sm:text-5xl md:text-6xl">
      {site.tagline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-escuro/70 dark:text-white/70">
      {site.descricao}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="/guias"
        class="rounded-full bg-rosa px-7 py-3 font-semibold text-white shadow-suave transition-transform hover:-translate-y-0.5"
      >
        Ver guias de compra
      </a>
      <a
        href="/enxoval"
        class="rounded-full border-2 border-lilas px-7 py-3 font-semibold text-lilas-dark transition-colors hover:bg-lilas hover:text-white dark:text-lilas-light"
      >
        Montar enxoval
      </a>
    </div>
  </div>
</section>
