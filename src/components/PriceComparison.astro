---
import { afiliados, comTagAfiliado } from '../config/affiliates';

interface LinhaPreco {
  plataforma: 'amazon' | 'mercadolivre' | 'shopee';
  url?: string;
  preco?: number;
}

interface Props {
  amazonUrl?: string;
  mercadolivreUrl?: string;
  shopeeUrl?: string;
  precoAmazon?: number;
  precoMercadolivre?: number;
  precoShopee?: number;
}

const {
  amazonUrl,
  mercadolivreUrl,
  shopeeUrl,
  precoAmazon,
  precoMercadolivre,
  precoShopee,
} = Astro.props;

const linhas: LinhaPreco[] = [
  { plataforma: 'amazon', url: comTagAfiliado(amazonUrl, 'amazon'), preco: precoAmazon },
  { plataforma: 'mercadolivre', url: comTagAfiliado(mercadolivreUrl, 'mercadolivre'), preco: precoMercadolivre },
  { plataforma: 'shopee', url: comTagAfiliado(shopeeUrl, 'shopee'), preco: precoShopee },
].filter((l) => l.url);

const formatarPreco = (v?: number) =>
  typeof v === 'number'
    ? v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })
    : 'Ver preço';

// Identifica o menor preço informado para destacar
const precosValidos = linhas.map((l) => l.preco).filter((p): p is number => typeof p === 'number');
const menorPreco = precosValidos.length ? Math.min(...precosValidos) : null;
---

{
  linhas.length > 0 && (
    <div class="my-8 overflow-hidden rounded-2xl border border-lilas/20 shadow-card">
      <table class="w-full border-collapse text-left">
        <caption class="bg-gradiente-mamae px-4 py-3 text-left text-sm font-bold uppercase tracking-wide text-white">
          Comparativo de preços
        </caption>
        <thead>
          <tr class="bg-rosa-light/10 text-sm text-escuro dark:bg-escuro/60 dark:text-white">
            <th class="px-4 py-3 font-semibold">Loja</th>
            <th class="px-4 py-3 font-semibold">Preço</th>
            <th class="px-4 py-3 text-right font-semibold">Comprar</th>
          </tr>
        </thead>
        <tbody>
          {linhas.map((linha) => {
            const melhor = menorPreco !== null && linha.preco === menorPreco;
            return (
              <tr class="border-t border-lilas/10 text-sm dark:text-white/90">
                <td class="px-4 py-4 font-medium">
                  {afiliados[linha.plataforma].nome}
                  {melhor && (
                    <span class="ml-2 rounded-full bg-rosa-dark px-2 py-0.5 text-xs font-bold text-white">
                      Menor preço
                    </span>
                  )}
                </td>
                <td class="px-4 py-4 font-semibold text-lilas-dark dark:text-lilas-light">
                  {formatarPreco(linha.preco)}
                </td>
                <td class="px-4 py-4 text-right">
                  <a
                    href={linha.url}
                    target="_blank"
                    rel="nofollow sponsored noopener"
                    class={`inline-flex rounded-full px-4 py-2 text-xs font-semibold text-white transition-transform hover:-translate-y-0.5 ${afiliados[linha.plataforma].cor}`}
                  >
                    Ver oferta
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p class="bg-rosa-light/5 px-4 py-2 text-xs text-escuro/70 dark:bg-escuro/40 dark:text-white/40">
        Preços coletados na data da publicação e sujeitos a alteração. Links de afiliado.
      </p>
    </div>
  )
}
