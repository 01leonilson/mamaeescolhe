---
interface Props {
  titulo: string;
  subtitulo?: string;
}
const { titulo, subtitulo } = Astro.props;
---

<section class="relative overflow-hidden border-b border-rosa-light/20">
  <div class="absolute inset-0 -z-10 bg-gradiente-mamae opacity-[0.07]"></div>
  <div class="mx-auto max-w-6xl px-4 py-14 text-center">
    <h1 class="bg-gradiente-mamae bg-clip-text text-3xl font-extrabold text-transparent sm:text-4xl">
      {titulo}
    </h1>
    {subtitulo && <p class="mx-auto mt-3 max-w-2xl text-escuro/70 dark:text-white/70">{subtitulo}</p>}
  </div>
</section>
