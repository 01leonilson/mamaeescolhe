---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateButtons from '../../components/AffiliateButtons.astro';
import PriceComparison from '../../components/PriceComparison.astro';
import { site } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const dataFormatada = data.date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const imagemAbsoluta = new URL(data.image, Astro.site ?? site.url).toString();

// Schema.org Article
const schema = {
  '@context': 'https://schema.org',
  '@type': data.type === 'review' ? 'Review' : 'Article',
  headline: data.title,
  description: data.description,
  image: imagemAbsoluta,
  datePublished: data.date.toISOString(),
  inLanguage: site.idioma,
  author: { '@type': 'Organization', name: site.autor },
  publisher: {
    '@type': 'Organization',
    name: site.nome,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', site.url).toString() },
  },
  ...(typeof data.price === 'number'
    ? {
        offers: {
          '@type': 'Offer',
          price: data.price,
          priceCurrency: 'BRL',
          availability: 'https://schema.org/InStock',
        },
      }
    : {}),
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.image}
  type="article"
  publishedDate={data.date}
  schema={schema}
>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-escuro/50 dark:text-white/50" aria-label="Breadcrumb">
      <a href="/" class="hover:text-rosa-dark">Início</a>
      <span class="mx-1">/</span>
      <a href={`/${data.category.toLowerCase()}`} class="hover:text-rosa-dark">{data.category}</a>
    </nav>

    <header class="mb-8">
      <span class="mb-3 inline-block rounded-full bg-gradiente-mamae px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
        {data.category}
      </span>
      <h1 class="text-3xl font-extrabold leading-tight text-escuro dark:text-white sm:text-4xl">
        {data.title}
      </h1>
      <p class="mt-4 text-lg text-escuro/70 dark:text-white/70">{data.description}</p>
      <p class="mt-4 text-sm text-escuro/50 dark:text-white/50">
        Publicado em {dataFormatada}
      </p>
    </header>

    <img
      src={data.image}
      alt={data.title}
      width="1280"
      height="720"
      class="mb-8 aspect-[16/9] w-full rounded-2xl object-cover shadow-card"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />

    <AffiliateButtons
      amazonUrl={data.amazon_url}
      mercadolivreUrl={data.mercadolivre_url}
      shopeeUrl={data.shopee_url}
      titulo={typeof data.price === 'number'
        ? `Veja o melhor preço — a partir de ${data.price.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}`
        : 'Veja onde comprar'}
    />

    <div class="prose-mamae">
      <Content />
    </div>

    {(data.type === 'comparativo' || data.type === 'review') && (
      <PriceComparison
        amazonUrl={data.amazon_url}
        mercadolivreUrl={data.mercadolivre_url}
        shopeeUrl={data.shopee_url}
        precoAmazon={data.price}
      />
    )}

    <AffiliateButtons
      amazonUrl={data.amazon_url}
      mercadolivreUrl={data.mercadolivre_url}
      shopeeUrl={data.shopee_url}
      titulo="Pronta para decidir? Compre com segurança"
    />
  </article>
</BaseLayout>
